<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.theatria</groupId>
    <artifactId>theatria-onboarding</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>TheatriaOnboarding</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- ====================================================================
             ADJUST THESE TWO IF THE BUILD OR PLUGIN LOAD COMPLAINS
             - paper.version : the paper-api artifact. It is versioned by the
                               Minecraft version, NOT a server build number, e.g.
                               1.21-R0.1-SNAPSHOT or 1.21.4-R0.1-SNAPSHOT. Keep
                               it in sync with api-version in plugin.yml. If Maven
                               can't resolve it, run /version on the server and use
                               that Minecraft version's "-R0.1-SNAPSHOT" artifact.
             - java.version  : the JDK your server runs on (17, 21, ...).
                               Defaulted to 21; change if your server needs another.
             ==================================================================== -->
        <paper.version>1.21-R0.1-SNAPSHOT</paper.version>
        <java.version>21</java.version>
    </properties>

    <repositories>
        <repository>
            <id>papermc</id>
            <url>https://repo.papermc.io/repository/maven-public/</url>
        </repository>
        <repository>
            <id>jitpack.io</id>
            <url>https://jitpack.io</url>
        </repository>
    </repositories>

    <dependencies>
        <!-- Server API (provided by the running server, not bundled). -->
        <dependency>
            <groupId>io.papermc.paper</groupId>
            <artifactId>paper-api</artifactId>
            <version>${paper.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Optional: economy lookups for the EARN task. Soft-depend at runtime;
             the plugin degrades to a /sell command listener if Vault is absent. -->
        <dependency>
            <groupId>com.github.MilkBowl</groupId>
            <artifactId>VaultAPI</artifactId>
            <version>1.7</version>
            <scope>provided</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>${project.name}-${project.version}</finalName>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>${java.version}</release>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
